<Window x:Class="SatelliteGalileoApp.MainWindow"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SatelliteGalileoApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <xctk:IntegerUpDown x:Name="controlSigma" Minimum="10" Maximum="20" Value="10" Width =" 50" Height="25" VerticalAlignment="top" Margin="34,60,698,300" />
        <xctk:IntegerUpDown x:Name="controlMu" Minimum="35" Maximum="75" Value="50" Width =" 50" Height="25" VerticalAlignment="top" Margin="146,60,582,300" />
        <Button x:Name="btnLoadData" Content="Load Sensor Data" HorizontalAlignment="Left" Margin="34,95,0,0" VerticalAlignment="Top" Width="184" Click="btnLoadData_Click"/>
        <ListView x:Name="bothDataList" HorizontalAlignment="Left" Height="271" Margin="34,120,0,0" VerticalAlignment="Top" Width="184" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView ColumnHeaderStringFormat="">
                    <GridViewColumn Header="SensorA" DisplayMemberBinding="{Binding SensorA}" Width ="100"/>
                    <GridViewColumn Header="SensorB" DisplayMemberBinding="{Binding SensorB}" Width ="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Button x:Name="btnSelectionSortA" Content="Sort" HorizontalAlignment="Left" Margin="254,82,0,0" VerticalAlignment="Top" Width="35" Click="btnSelectionSortA_Click"/>
        <TextBox x:Name="timeSelectionSortA" HorizontalAlignment="Left" Height="20" Margin="294,82,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="54"/>
        <Button x:Name="btnInsertionSortA" Content="Sort" HorizontalAlignment="Left" Height="21" Margin="254,136,0,0" VerticalAlignment="Top" Width="35" Click="btnInsertionSortA_Click"/>
        <TextBox x:Name="timeInsertionSortA" HorizontalAlignment="Left" Height="21" Margin="294,136,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="54"/>
        <Label Content="Selection Sort" HorizontalAlignment="Left" Height="29" Margin="254,48,0,0" VerticalAlignment="Top" Width="94"/>
        <Label Content="Insertion Sort" HorizontalAlignment="Left" Height="30" Margin="254,107,0,0" VerticalAlignment="Top" Width="94"/>
        <Label Content="Target" HorizontalAlignment="Left" Height="27" Margin="254,169,0,0" VerticalAlignment="Top" Width="83"/>
        <TextBox x:Name="inputTargetA" HorizontalAlignment="Left" Height="21" Margin="254,196,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="94"/>
        <Label Content="Search Iterative" HorizontalAlignment="Left" Height="26" Margin="253,238,0,0" VerticalAlignment="Top" Width="96"/>
        <Button x:Name="btnIterativeSearchA" Content="Search" HorizontalAlignment="Left" Height="23" Margin="254,276,0,0" VerticalAlignment="Top" Width="42" Click="btnIterativeSearchA_Click"/>
        <TextBox x:Name="timeIterativeSearchA" HorizontalAlignment="Left" Height="23" Margin="301,276,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="48"/>
        <Label Content="Search Recursive" HorizontalAlignment="Left" Height="29" Margin="254,319,0,0" VerticalAlignment="Top" Width="102"/>
        <Button x:Name="btnRecursiveSearchA" Content="Search" HorizontalAlignment="Left" Height="23" Margin="254,353,0,0" VerticalAlignment="Top" Width="47" Click="btnRecursiveSearchA_Click"/>
        <TextBox x:Name="timeRecursiveSearchA" HorizontalAlignment="Left" Height="23" Margin="306,353,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="50"/>
        <Label Content="SensorA" HorizontalAlignment="Left" Height="38" Margin="321,10,0,0" VerticalAlignment="Top" Width="134" FontSize="22"/>
        <Viewbox HorizontalAlignment="Left" Height="323" Margin="396,53,0,0" VerticalAlignment="Top" Width="122"/>
        <ListBox x:Name="lBoxSensorA" HorizontalAlignment="Left" Height="318" Margin="375,66,0,0" VerticalAlignment="Top" Width="108"/>
        <Label Content="SensorB" HorizontalAlignment="Left" Height="38" Margin="596,10,0,0" VerticalAlignment="Top" Width="134" FontSize="22"/>
        <Label Content="Selection Sort" HorizontalAlignment="Left" Height="29" Margin="518,52,0,0" VerticalAlignment="Top" Width="94"/>
        <Label Content="Insertion Sort" HorizontalAlignment="Left" Height="30" Margin="520,116,0,0" VerticalAlignment="Top" Width="94"/>
        <Label Content="Target" HorizontalAlignment="Left" Height="27" Margin="523,169,0,0" VerticalAlignment="Top" Width="83"/>
        <Label Content="Search Iterative" HorizontalAlignment="Left" Height="25" Margin="523,243,0,0" VerticalAlignment="Top" Width="96"/>
        <Label Content="Search Recursive" HorizontalAlignment="Left" Height="29" Margin="518,319,0,0" VerticalAlignment="Top" Width="102"/>
        <Button x:Name="btnSelectionSortB" Content="Sort" HorizontalAlignment="Left" Height="23" Margin="523,82,0,0" VerticalAlignment="Top" Width="34" Click="btnSelectionSortB_Click"/>
        <Button x:Name="btnInsertionSortB" Content="Sort" HorizontalAlignment="Left" Height="23" Margin="523,140,0,0" VerticalAlignment="Top" Width="34" Click="btnInsertionSortB_Click"/>
        <TextBox x:Name="timeSelectionSortB" HorizontalAlignment="Left" Height="23" Margin="564,82,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="56"/>
        <TextBox x:Name="timeInsertionSortB" HorizontalAlignment="Left" Height="24" Margin="565,140,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="59"/>
        <TextBox x:Name="inputTargetB" HorizontalAlignment="Left" Height="21" Margin="523,196,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="101"/>
        <Button x:Name="btnIterativeSearchB" Content="Button" HorizontalAlignment="Left" Height="23" Margin="527,276,0,0" VerticalAlignment="Top" Width="44"/>
        <Button x:Name="btnRecursiveSearchB" Content="Button" HorizontalAlignment="Left" Height="23" Margin="527,353,0,0" VerticalAlignment="Top" Width="44"/>
        <TextBox x:Name="timeIterativeSearchB" HorizontalAlignment="Left" Height="23" Margin="578,276,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46"/>
        <TextBox x:Name="timeRecursiveSearchB" HorizontalAlignment="Left" Height="23" Margin="578,353,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46"/>
        <ListBox x:Name="lBoxSensorB" HorizontalAlignment="Left" Height="321" Margin="647,63,0,0" VerticalAlignment="Top" Width="106" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Label Content="Sigma" HorizontalAlignment="Left" Height="28" Margin="45,34,0,0" VerticalAlignment="Top" Width="46"/>
        <Label Content="Mu" HorizontalAlignment="Left" Height="28" Margin="159,34,0,0" VerticalAlignment="Top" Width="46"/>

    </Grid>

</Window>
